{
  "layer": "top",
  "position": "top",
  "spacing": 8,
  "modules-left": [
    "niri/workspaces"
  ],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/virtual-camera",
    "custom/desktop-recording",
    "custom/audio-recording",
    "pulseaudio",
    "custom/power"
  ],
  "niri/workspaces": {
    "format": "{icon}"
  },
  "clock": {
    "timezone": "US/Eastern",
    "tooltip": false,
    "format": "{:%b %d %H:%M}"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-muted": "🔇 Muted",
    "format-icons": {
      "alsa_output.usb-Focusrite_Scarlett_2i2_USB_Y8CZJFM0AA378C-00.HiFi__Line__sink": "🎧",
      "alsa_output.usb-Focusrite_Scarlett_2i2_USB_Y8CZJFM0AA378C-00.HiFi__Line__sink-muted": "🎧",
      "alsa_output.pci-0000_09_00.1.hdmi-stereo-extra4": "🖥️",
      "alsa_output.pci-0000_09_00.1.hdmi-stereo-extra4-muted": "🖥️",
      "bluez_output.94_4F_4C_03_D5_4C.1": "📢",
      "bluez_output.94_4F_4C_03_D5_4C.1-muted": "📢",
      "default": ["🔈", "🔉", "🔊"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "scroll-step": 5
  },
  "custom/virtual-camera": {
    "exec": "~/dev/dot_files/bin/.bin/fuzzel/toggle-virtual-camera.sh --status",
    "return-type": "json",
    "interval": 2,
    "on-click": "~/dev/dot_files/bin/.bin/fuzzel/toggle-virtual-camera.sh"
  },
  "custom/desktop-recording": {
    "exec": "~/dev/dot_files/bin/.bin/fuzzel/toggle-desktop-recording.sh --status",
    "return-type": "json",
    "interval": 2,
    "on-click": "~/dev/dot_files/bin/.bin/fuzzel/toggle-desktop-recording.sh"
  },
  "custom/audio-recording": {
    "exec": "~/dev/dot_files/bin/.bin/fuzzel/toggle-audio-recording.sh --status",
    "return-type": "json",
    "interval": 2,
    "on-click": "~/dev/dot_files/bin/.bin/fuzzel/toggle-audio-recording.sh"
  },
  "custom/power": {
    "format": "⏻",
    "on-click": "sh -c 'systemctl $(printf \"poweroff\\nreboot\\nhibernate\" | fuzzel --dmenu)'",
    "tooltip": false
  }
}
